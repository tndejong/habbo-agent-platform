RCON_HOST=127.0.0.1
RCON_PORT=3001
DB_HOST=127.0.0.1
DB_PORT=13306
DB_NAME=arcturus
DB_USER=arcturus_user
DB_PASSWORD=arcturus_pw
MCP_API_KEY=change-me-to-a-secret
HABBO_BASE_URL=http://127.0.0.1:1080

# Optional: start an SSH tunnel automatically before MCP boot
# Set SSH_TUNNEL_ENABLED=true when your emulator runs on a remote server.
SSH_TUNNEL_ENABLED=false
SSH_TUNNEL_HOST=
SSH_TUNNEL_PORT=22
SSH_TUNNEL_USER=
SSH_TUNNEL_KEY_PATH=
SSH_TUNNEL_STRICT_HOST_KEY_CHECKING=accept-new
SSH_TUNNEL_CONNECT_TIMEOUT_SEC=10
SSH_TUNNEL_START_TIMEOUT_MS=30000
SSH_TUNNEL_LOCAL_RCON_PORT=43001
SSH_TUNNEL_REMOTE_RCON_HOST=127.0.0.1
SSH_TUNNEL_REMOTE_RCON_PORT=13001
SSH_TUNNEL_LOCAL_DB_PORT=43306
SSH_TUNNEL_REMOTE_DB_HOST=127.0.0.1
SSH_TUNNEL_REMOTE_DB_PORT=13306

# Hook: spawn bots in-hotel on Cursor agent events
HABBO_HOOK_ENABLED=false
