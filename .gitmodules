[submodule "emulator/arcturus"]
	path = emulator/arcturus
	url = https://github.com/tndejong/arcturus-community.git
[submodule "nitro/nitro-react"]
	path = nitro/nitro-react
	url = https://github.com/tndejong/nitro-react.git
[submodule "nitro/nitro-converter"]
	path = nitro/nitro-converter
	url = https://github.com/billsonnn/nitro-converter.git
[submodule "nitro/nitro-swf"]
	path = nitro/nitro-swf
	url = https://git.krews.org/morningstar/arcturus-morningstar-default-swf-pack.git
[submodule "nitro/nitro-assets"]
	path = nitro/nitro-assets
	url = https://git.krews.org/nitro/default-assets.git
	ignore = untracked
[submodule "hooks"]
	path = hooks
	url = https://github.com/tndejong/habbo-hooks-client.git
	branch = main
